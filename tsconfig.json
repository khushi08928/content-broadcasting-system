{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true
    },
    "include": [
        "index.ts",
        "controllers/**/*",
        "db/**/*",
        "middlewares/**/*",
        "models/**/*",
        "routes/**/*",
        "services/**/*",
        "utils/**/*",
        "types/**/*"
    ],
    "exclude": ["node_modules", "dist", "drizzle"]
}
